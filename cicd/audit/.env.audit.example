# Docker audit quickstart — fill in the cloud(s) you have; blank ones are skipped.
#   cp cicd/audit/.env.audit.example cicd/audit/.env.audit   # then fill in the values
#   docker compose -f compose.audit.yaml run --rm audit

# --- AWS (temporary/session credentials) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# --- GCP (service-account key JSON, inline on one line) ---
# Whole-org sweep: set GOOGLE_ORG_ID (digits only) to descend all projects.
GCP_SA_JSON=
GOOGLE_ORG_ID=

# --- Azure / Entra ---
# Whole-tenant sweep by default; set AZURE_MGMT_GROUP to scope to one mgmt group.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_MGMT_GROUP=

# --- Pinned audit engine (queries + scripts downloaded at run time) ---
# Per-target wall-clock cap in seconds (prevents a slow target hanging the run)
STACKQL_DEEP_TIMEOUT=300

AUDIT_ENGINE_REF=4d02dccad5d9b9a79d04c4c48af88e1fb4149aff

# --- Pinned provider registry versions (reproducible audits) ---
AWS_PROVIDER_VERSION=v26.07.00414
GOOGLE_PROVIDER_VERSION=v25.12.00357
AZURE_PROVIDER_VERSION=v26.07.00420
ENTRA_PROVIDER_VERSION=v26.06.00405

# keep the audit light touch by default
STACKQL_AUDIT_SKIP='*storage* s3/*' python3 scripts/discover.py gcp-org

